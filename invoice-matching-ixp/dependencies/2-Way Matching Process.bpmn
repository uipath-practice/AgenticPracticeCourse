    <bpmn:textAnnotation id="Text_eesI4d">
      <bpmn:text>AGENT: compare documents and find discrepancies</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_1WToi9">
      <bpmn:documentation>HITL: Validation App that explains mismatch and allows to Approve or Reject</bpmn:documentation>
      <bpmn:text>Human in the loop: Validation Task for review. Decision: Approve or Reject</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_zxaaHW">
      <bpmn:documentation>Data Service: add transaction record</bpmn:documentation>
      <bpmn:text>Data Service: add transaction record for payment processing</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_OSNmFU">
      <bpmn:text>Integration Service (GMail): Send Email Message</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_Rb7PdI">
      <bpmn:text>ROBOT: Retrieve Invoice &amp; Purchase Order (JSON objects) </bpmn:text>
    </bpmn:textAnnotation>
  </bpmn:process>
