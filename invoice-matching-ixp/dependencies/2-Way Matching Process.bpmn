      </bpmn:extensionElements>
      <bpmn:outgoing>edge___Event_jjdkDo-Activity_zQtGNV</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_zQtGNV" name="Retrieve data for next PO and Invoice">
      <bpmn:documentation>Retrieve data for next PO and Invoice</bpmn:documentation>
      <bpmn:incoming>edge___Event_jjdkDo-Activity_zQtGNV</bpmn:incoming>
      <bpmn:outgoing>edge___Activity_zQtGNV-Activity_CjAznd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_CjAznd" name="Compare Invoice against Purchase Order">
      <bpmn:documentation>Perform 2-way matching</bpmn:documentation>
      <bpmn:incoming>edge___Activity_zQtGNV-Activity_CjAznd</bpmn:incoming>
      <bpmn:outgoing>edge___Activity_CjAznd-Gateway_PCsPAZ</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_PCsPAZ" name="Comparison results" default="edge___Gateway_PCsPAZ-Activity_AphyH5">
      <bpmn:incoming>edge___Activity_CjAznd-Gateway_PCsPAZ</bpmn:incoming>
      <bpmn:outgoing>edge___Gateway_PCsPAZ-Activity_jlbtMj</bpmn:outgoing>
      <bpmn:outgoing>edge___Gateway_PCsPAZ-Activity_AphyH5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_jlbtMj" name="Update Financial Systems">
      <bpmn:documentation>Update Financial Systems</bpmn:documentation>
      <bpmn:incoming>edge___Gateway_PCsPAZ-Activity_jlbtMj</bpmn:incoming>
      <bpmn:incoming>edge___Gateway_bM9uct-Activity_jlbtMj</bpmn:incoming>
      <bpmn:outgoing>edge___Activity_jlbtMj-Event_U9ZynV5EeBAv</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_U9ZynV" name="Finish">
      <bpmn:incoming>edge___Activity_6B8gTv-Event_U9ZynV</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Activity_AphyH5" name="Manual Review and Validation">
      <bpmn:documentation>Manual Validation</bpmn:documentation>
      <bpmn:incoming>edge___Gateway_PCsPAZ-Activity_AphyH5</bpmn:incoming>
      <bpmn:outgoing>edge___Activity_AphyH5-Gateway_bM9uct</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_bM9uct" name="Reviewer Decision" default="edge___Gateway_bM9uct-Activity_6B8gTv">
      <bpmn:incoming>edge___Activity_AphyH5-Gateway_bM9uct</bpmn:incoming>
      <bpmn:outgoing>edge___Gateway_bM9uct-Activity_6B8gTv</bpmn:outgoing>
      <bpmn:outgoing>edge___Gateway_bM9uct-Activity_jlbtMj</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_6B8gTv" name="Send rejection Email to Vendor">
      <bpmn:documentation>Reject invoice by sending email or message</bpmn:documentation>
      <bpmn:incoming>edge___Gateway_bM9uct-Activity_6B8gTv</bpmn:incoming>
      <bpmn:outgoing>edge___Activity_6B8gTv-Event_U9ZynV</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_MAu8of" name="Finish">
      <bpmn:incoming>edge___Activity_jlbtMj-Event_U9ZynV5EeBAv</bpmn:incoming>
    </bpmn:endEvent>
