      <bpmn:documentation>"Full match"</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="edge___Gateway_PCsPAZ-Activity_AphyH5" name="Issues detected" sourceRef="Gateway_PCsPAZ" targetRef="Activity_AphyH5">
      <bpmn:documentation>"Failed Match"</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="edge___Activity_AphyH5-Gateway_bM9uct" sourceRef="Activity_AphyH5" targetRef="Gateway_bM9uct" />
    <bpmn:sequenceFlow id="edge___Gateway_bM9uct-Activity_6B8gTv" name="Reject" sourceRef="Gateway_bM9uct" targetRef="Activity_6B8gTv">
      <bpmn:documentation>Reject</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="edge___Gateway_bM9uct-Activity_jlbtMj" name="Approve" sourceRef="Gateway_bM9uct" targetRef="Activity_jlbtMj">
      <bpmn:documentation>Approve</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
